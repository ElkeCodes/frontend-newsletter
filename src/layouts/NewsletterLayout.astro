---
export interface Props {
  frontmatter?: {
    title?: string;
    subject?: string;
    date?: string;
    author?: string;
  };
}

const { frontmatter = {} } = Astro.props;
const title = frontmatter.title ?? 'Untitled Newsletter';
const subject = frontmatter.subject ?? title;
const rawDate = frontmatter.date ?? new Date().toISOString().split('T')[0];
const date =
  rawDate instanceof Date
    ? rawDate.toISOString().split('T')[0]
    : String(rawDate).split('T')[0];
const author = frontmatter.author;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        font-size: 16px;
        --bg-body: #f9f9f9;
        --bg-container: #ffffff;
        --bg-code: #f4f4f4;
        --text-primary: #333;
        --text-secondary: #666;
        --text-muted: #999;
        --border-color: #eee;
        --border-dark: #ddd;
        --link-color: #0066cc;
        --shadow: 0 0.0625rem 0.1875rem rgba(0, 0, 0, 0.1);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg-body: #1a1a1a;
          --bg-container: #2a2a2a;
          --bg-code: #383838;
          --text-primary: #e0e0e0;
          --text-secondary: #b0b0b0;
          --text-muted: #666;
          --border-color: #444;
          --border-dark: #555;
          --link-color: #66b3ff;
          --shadow: 0 0.0625rem 0.1875rem rgba(0, 0, 0, 0.5);
        }
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell,
          sans-serif;
        color: var(--text-primary);
        line-height: 1.6;
        padding: 1.25rem;
        background-color: var(--bg-body);
      }

      article {
        max-width: 37.5rem;
        margin: 0 auto;
        background-color: var(--bg-container);
        padding: 2.5rem;
        border-radius: 0.25rem;
        box-shadow: var(--shadow);
      }

      header {
        border-bottom: 0.125rem solid var(--border-color);
        margin-bottom: 1.875rem;
        padding-bottom: 1.25rem;
      }

      h1 {
        margin: 0 0 0.625rem 0;
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-primary);
      }

      .meta {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        margin-top: 0.5rem;
      }

      main {
        font-size: 1rem;
        color: var(--text-primary);
      }

      main :global(h2),
      main :global(h3),
      main :global(h4) {
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
        color: var(--text-primary);
        font-weight: 600;
      }

      main :global(h2) {
        font-size: 1.25rem;
      }

      main :global(h3) {
        font-size: 1.125rem;
      }

      main :global(h4) {
        font-size: 1rem;
      }

      main :global(p) {
        margin: 0.75rem 0;
      }

      main :global(a) {
        color: var(--link-color);
        text-decoration: none;
      }

      main :global(a:hover) {
        text-decoration: underline;
      }

      main :global(ul),
      main :global(ol) {
        margin: 0.75rem 0;
        padding-left: 1.5rem;
      }

      main :global(li) {
        margin: 0.375rem 0;
      }

      main :global(code) {
        background-color: var(--bg-code);
        color: var(--text-primary);
        padding: 0.125rem 0.375rem;
        border-radius: 0.1875rem;
        font-family: 'Courier New', monospace;
        font-size: 0.875rem;
      }

      main :global(pre) {
        background-color: var(--bg-code);
        color: var(--text-primary);
        padding: 0.75rem;
        border-radius: 0.25rem;
        overflow-x: auto;
        margin: 0.75rem 0;
      }

      main :global(pre code) {
        background-color: transparent;
        color: inherit;
        padding: 0;
      }

      main :global(blockquote) {
        border-left: 0.1875rem solid var(--border-dark);
        margin: 0.75rem 0;
        padding-left: 0.75rem;
        color: var(--text-secondary);
      }

      footer {
        border-top: 0.125rem solid var(--border-color);
        margin-top: 1.875rem;
        padding-top: 1.25rem;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-align: center;
      }

      time {
        white-space: nowrap;
      }

      address {
        display: inline;
        font-style: normal;
      }
    </style>
  </head>
  <body>
    <article>
      <header>
        <h1>{title}</h1>
        <p class="meta">
          <strong>Subject:</strong> {subject}
          {' | '}
          <strong>Date:</strong> <time>{date}</time>
          {author && (
            <>
              {' | '}
              <strong>Author:</strong> <address>{author}</address>
            </>
          )}
        </p>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <p>This is an automated newsletter. Please do not reply to this email.</p>
      </footer>
    </article>
  </body>
</html>
