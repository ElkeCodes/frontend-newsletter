---
export interface Props {
  frontmatter?: {
    title?: string;
    subject?: string;
    date?: string;
    author?: string;
  };
}

const { frontmatter = {} } = Astro.props;
const title = frontmatter.title ?? "Untitled Newsletter";
const subject = frontmatter.subject ?? title;
const rawDate = frontmatter.date ?? new Date().toISOString().split("T")[0];
const date =
  rawDate instanceof Date
    ? rawDate.toISOString().split("T")[0]
    : String(rawDate).split("T")[0];
const author = frontmatter.author;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        font-size: 16px;
        --bg-body: #f9f9f9;
        --bg-container: #ffffff;
        --bg-code: #f4f4f4;
        --text-primary: #2a1449;
        --text-secondary: #604486;
        --text-muted: #545454;
        --border-color: #d0d0d0;
        --border-dark: #a3a2a0;
        --link-color: #604486;
        --link-color-hover: #4c3172;
        --border-radius: 0.25rem;
        --shadow: 0 0.0625rem 0.1875rem rgba(0, 0, 0, 0.1);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg-body: #1a1a1a;
          --bg-container: #2a2a2a;
          --bg-code: #383838;
          --text-primary: #e0e0e0;
          --text-secondary: #cccccc;
          --text-muted: #c0c0c0;
          --border-color: #444;
          --border-dark: #555;
          --link-color: #d4b8ff;
          --link-color-hover: #e8d5ff;
          --shadow: 0 0.0625rem 0.1875rem rgba(0, 0, 0, 0.5);
        }
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family:
          "Segoe UI",
          "Segoe UI Web (West European)",
          -apple-system,
          BlinkMacSystemFont,
          Roboto,
          "Helvetica Neue",
          sans-serif;
        color: var(--text-primary);
        line-height: 1.6;
        padding: 1.25rem;
        background-color: var(--bg-body);
      }

      article {
        max-width: 96ch;
        margin: 0 auto;
        background-color: var(--bg-container);
        padding: 2.5rem;
        border-radius: 0.25rem;
        box-shadow: var(--shadow);
      }

      header {
        border-bottom: 0.125rem solid var(--border-color);
        margin-bottom: 1.875rem;
        padding-bottom: 1.25rem;
      }

      h1 {
        margin: 0 0 0.625rem 0;
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.01em;
      }

      .meta {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        margin-top: 0.5rem;
      }

      .content {
        font-size: 1.25rem;
        color: var(--text-primary);
      }

      .content :global(h2),
      .content :global(h3),
      .content :global(h4) {
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
        color: var(--text-primary);
        font-weight: 600;
      }

      .content :global(h2) {
        font-size: 1.375rem;
      }

      .content :global(h3) {
        font-size: 1.125rem;
      }

      .content :global(h4) {
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-secondary);
      }

      .content :global(p) {
        margin: 0.75rem 0;
      }

      .content :global(a) {
        color: var(--link-color);
        text-decoration: none;
      }

      .content :global(a:hover) {
        color: var(--link-color-hover);
        text-decoration: underline;
      }

      .content :global(ul),
      .content :global(ol) {
        margin: 0.75rem 0;
        padding-left: 1.5rem;
      }

      .content :global(li) {
        margin: 0.375rem 0;
      }

      .content :global(code) {
        background-color: var(--bg-code);
        color: var(--text-primary);
        padding: 0.125rem 0.375rem;
        border-radius: 0.1875rem;
        font-family: "Courier New", monospace;
        font-size: 0.875rem;
      }

      .content :global(pre) {
        background-color: var(--bg-code);
        color: var(--text-primary);
        padding: 0.25rem 0.75rem;
        border-radius: 0.25rem;
        overflow-x: auto;
        margin: 0.75rem 0;
      }

      .content :global(pre code) {
        background-color: transparent;
        color: inherit;
        padding: 0;
      }

      .content :global(blockquote) {
        border-left: 0.25rem solid var(--link-color);
        margin: 0.75rem 0;
        padding: 0.5rem 0.75rem;
        color: var(--text-primary);
        background-color: var(--bg-code);
        border-radius: 0 0.25rem 0.25rem 0;
      }

      footer {
        border-top: 0.125rem solid var(--border-color);
        margin-top: 1.875rem;
        padding-top: 1.25rem;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-align: center;
      }

      time {
        white-space: nowrap;
      }

      address {
        display: inline;
        font-style: normal;
      }

      .content :global(hr) {
        border: none;
        border-top: 0.125rem solid var(--border-color);
        margin: 1.5rem 0;
      }

      /* Skip navigation link (visible on focus for keyboard users) */
      .skip-link {
        position: absolute;
        top: -100%;
        left: 0;
        padding: 0.5rem 1rem;
        background: var(--bg-container);
        color: var(--link-color);
        font-weight: 600;
        text-decoration: none;
        border: 0.125rem solid var(--link-color);
        border-radius: 0 0 0.25rem 0;
        z-index: 100;
      }

      .skip-link:focus-visible {
        top: 0;
      }

      /* Focus indicators — WCAG 2.4.7 / 2.4.13 */
      :focus-visible {
        outline: 0.1875rem solid var(--link-color);
        outline-offset: 0.125rem;
        border-radius: 0.125rem;
      }

      /* Honour reduced-motion preference — WCAG 2.3.3 */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <main>
      <article>
        <header>
          <h1>{title}</h1>
          <p class="meta">
            <strong>Subject:</strong>
            {subject}
            {" | "}
            <strong>Date:</strong>
            <time datetime={date}>{date}</time>
            {
              author && (
                <>
                  {" | "}
                  <strong>Author:</strong> <address>{author}</address>
                </>
              )
            }
          </p>
        </header>
        <div id="main-content" class="content">
          <slot />
        </div>
        <footer>
          <p>
            This is an automated newsletter. Please do not reply to this email.
          </p>
        </footer>
      </article>
    </main>
  </body>
</html>
